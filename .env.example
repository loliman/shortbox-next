# Database Connection URL (Prisma / application database)
DATABASE_URL="postgresql://username:password@localhost:5432/shortbox?schema=shortbox"

# Host and Port configuration (Docker/Production)
# PORT=3000
# HOST=0.0.0.0

# Site URL for generating SEO canonical links & sitemap
NEXT_PUBLIC_SITE_URL="https://shortbox.de"

# Background Worker Settings
WORKER_CONCURRENCY=5

# Login Security & Rate Limiting
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=60
LOGIN_LOCK_SECONDS=900

# Other internal parameters
STORY_FILTER_BATCH_SIZE=250
CLEANUP_DRY_RUN=false

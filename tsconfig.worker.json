{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024", "DOM"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "esModuleInterop": true,
    "module": "Node16",
    "moduleResolution": "Node16",
    "resolveJsonModule": true,
    "isolatedModules": false,
    "incremental": false,
    "declaration": false,
    "sourceMap": false,
    "outDir": "dist/worker",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/worker.tsbuildinfo",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "files": ["src/worker/index.ts"],
  "exclude": [
    "node_modules",
    ".next",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/services/MarvelCrawlerService.ts"
  ]
}
